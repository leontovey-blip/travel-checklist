{
  "name": "travel-checklist-app",
  "version": "1.0.0",
  "description": "旅行物品备忘录 - 轻松管理你的旅行清单",
  "main": "travel-checklist.html",
  "scripts": {
    "cap:init": "npx cap init \"旅行清单\" com.travel.checklist --web-dir=. --force",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "build": "echo 'No build step required - using static HTML'",
    "start": "npx http-server . -p 8080 -o"
  },
  "keywords": [
    "travel",
    "checklist",
    "pwa",
    "capacitor"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@capacitor/android": "^5.0.0",
    "@capacitor/core": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.0.0",
    "http-server": "^14.1.1"
  }
}
